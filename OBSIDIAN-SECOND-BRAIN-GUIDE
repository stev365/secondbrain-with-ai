  role_icon: 'if(role == "advisor", "🎓", if(role == "peer", "🤝", if(role == "industry", "💼", if(role == "friend", "❤️", "📇"))))'

properties:
  formula.role_icon:
    displayName: ""
  role:
    displayName: "Role"
  organization:
    displayName: "Organization"
  last-contact:
    displayName: "Last Contact"
  formula.days_since_contact:
    displayName: "Days since contact"

views:
  - type: table
    name: "All People"
    order:
      - formula.role_icon
      - file.name
      - role
      - organization
      - last-contact
      - formula.days_since_contact
```

